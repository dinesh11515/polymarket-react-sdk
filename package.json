{
  "name": "polymarket-react-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Polymarket React SDK monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dinesh11515/polymarket-react-sdk.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r --sort --if-present run build",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "clean": "rimraf packages/*/dist",
    "dev": "pnpm --filter vite-react dev",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "simple-git-hooks",
    "release:publish": "changeset publish",
    "typecheck": "pnpm -r --sort --if-present run typecheck",
    "test": "pnpm test:react",
    "test:react": "vitest --project react",
    "version-packages": "changeset version"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": [
      "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.5.0",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
