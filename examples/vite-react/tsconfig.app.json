{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "paths": {
      "polymarket-react-sdk": ["../../packages/react/src/exports/index.ts"],
      "polymarket-react-sdk/query": [
        "../../packages/react/src/exports/query.ts"
      ],
      "polymarket-react-sdk/viem": ["../../packages/react/src/exports/viem.ts"]
    }
  },
  "include": ["src"]
}
